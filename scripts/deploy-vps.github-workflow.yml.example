# Скопируй в .github/workflows/deploy-vps.yml когда будешь включать Actions.
# Первый push без этого файла — если GitHub ругается на scope «workflow», создай файл вручную в UI репозитория.
#
# Secrets: VPS_HOST, VPS_USER, VPS_SSH_KEY, VPS_APP_DIR, опционально VPS_SYSTEMD_SERVICE
name: Deploy to VPS

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: SSH — git pull и деплой
        uses: appleboy/ssh-action@v1.2.0
        with:
          host: ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USER }}
          key: ${{ secrets.VPS_SSH_KEY }}
          script_stop: true
          script: |
            set -euo pipefail
            cd "${{ secrets.VPS_APP_DIR }}"
            git fetch origin main
            git checkout main
            git pull --ff-only origin main
            export NODE_ENV=production
            chmod +x scripts/vps-deploy.sh || true
            SYSTEMD_SERVICE="${{ secrets.VPS_SYSTEMD_SERVICE }}" bash scripts/vps-deploy.sh
